from datetime import datetime
import json

def calculate_threat_score(signal, patterns=None):
    """
    Calculate threat score 0-10 based on multiple factors.
    """
    score = 0.0

    # Hostility contribution (0-4 points)
    hostility = signal.get("hostility_score", 0.0)
    score += hostility * 4.0

    # Sentiment contribution (0-3 points, negative sentiment = higher threat)
    sentiment = signal.get("sentiment_score", 0.0)
    if sentiment < -0.5:
        score += 3.0
    elif sentiment < -0.2:
        score += 2.0
    elif sentiment < 0:
        score += 1.0

    # Pattern match bonus (0-2 points)
    if patterns:
        high_threat_patterns = ["military_escalation", "ceasefire_violation", "war_crime"]
        critical_patterns = ["atrocity", "massacre", "genocide"]

        for pattern in patterns:
            if pattern in high_threat_patterns:
                score += 0.5
            elif pattern in critical_patterns:
                score += 1.0

    # Source credibility adjustment (0-1 points)
    source = signal.get("source", "")
    source_credibility = {
        "X (Twitter)": 0.3,
        "Reddit": 0.2,
        "Telegram": 0.4,
        "NewsAPI": 0.5,
        "GDELT": 0.6,
        "Open Source Intel": 0.7,
    }
    score += source_credibility.get(source, 0.3)

    # Geographic specificity bonus
    if signal.get("geo_tag"):
        score += 0.5

    # Actor specificity bonus
    actors = signal.get("actors", [])
    if isinstance(actors, str):
        try:
            actors = json.loads(actors)
        except:
            actors = []
    if actors and len(actors) > 0:
        score += 0.3

    return min(10.0, round(score, 1))

def calculate_velocity(signals, time_window_hours=6):
    """
    Calculate signal velocity - rate of concerning signals per hour.
    """
    if not signals:
        return 0.0

    now = datetime.utcnow()
    window_seconds = time_window_hours * 3600

    recent_signals = []
    for s in signals:
        try:
            ts = datetime.fromisoformat(s.get("timestamp", ""))
            age = (now - ts).total_seconds()
            if age <= window_seconds:
                recent_signals.append(s)
        except:
            continue

    if not recent_signals:
        return 0.0

    # Count concerning signals (hostility > 0.5 or threat patterns)
    concerning = sum(1 for s in recent_signals if s.get("hostility_score", 0) > 0.5)

    velocity = (concerning / time_window_hours) * 10  # Scale to 0-10

    return min(10.0, round(velocity, 1))

def get_threat_level(score):
    """Convert numeric score to threat level label."""
    if score >= 8.0:
        return "CRITICAL"
    elif score >= 7.0:
        return "HIGH"
    elif score >= 5.0:
        return "MEDIUM"
    elif score >= 3.0:
        return "LOW"
    else:
        return "MINIMAL"

def get_threat_color(score):
    """Get color code for threat level."""
    if score >= 8.0:
        return "#ef4444"  # Red
    elif score >= 7.0:
        return "#f97316"  # Orange
    elif score >= 5.0:
        return "#eab308"  # Yellow
    elif score >= 3.0:
        return "#22c55e"  # Green
    else:
        return "#3b82f6"  # Blue
