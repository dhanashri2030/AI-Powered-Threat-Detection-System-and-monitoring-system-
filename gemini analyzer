import json
import os
import requests
from config import GEMINI_API_KEY

def analyze_with_gemini(content, signals_context=None):
    """
    Analyze content using Gemini API.
    Falls back to rule-based analysis if no API key is available.
    """
    if not GEMINI_API_KEY:
        return rule_based_analysis(content, signals_context)

    try:
        url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key={GEMINI_API_KEY}"

        prompt = f"""Analyze this intelligence signal for conflict indicators.

Signal: {content}

Provide a JSON response with ONLY this format (no other text):
{{
    "threat_level": 0-10,
    "key_actors": ["actor1", "actor2"],
    "key_locations": ["location1", "location2"],
    "conflict_type": "military|political|humanitarian|cyber|general",
    "confidence": 0.0-1.0,
    "recommendation": "brief recommendation"
}}"""

        payload = {
            "contents": [{
                "parts": [{"text": prompt}]
            }],
            "generationConfig": {
                "temperature": 0.3,
                "maxOutputTokens": 500
            }
        }

        headers = {"Content-Type": "application/json"}

        response = requests.post(url, json=payload, headers=headers, timeout=30)

        if response.status_code == 200:
            result = response.json()
            text = result["candidates"][0]["content"]["parts"][0]["text"]

            # Extract JSON from response
            try:
                # Try to find JSON in the response
                json_str = text
                if "```json" in text:
                    json_str = text.split("```json")[1].split("```")[0]
                elif "```" in text:
                    json_str = text.split("```")[1].split("```")[0]

                return json.loads(json_str)
            except:
                # If JSON parsing fails, use rule-based
                return rule_based_analysis(content, signals_context)
        else:
            print(f"Gemini API error: {response.status_code}")
            return rule_based_analysis(content, signals_context)

    except Exception as e:
        print(f"Gemini API exception: {e}")
        return rule_based_analysis(content, signals_context)


def rule_based_analysis(content, signals_context=None):
    """
    Rule-based fallback analysis.
    Used when no API key is available.
    """
    content_lower = content.lower()

    # Threat keywords with weights
    threat_indicators = {
        "attack": 2.0, "invasion": 3.0, "war": 3.0, "massacre": 4.0,
        "killing": 2.5, "casualties": 2.0, "ceasefire violation": 2.5,
        "military buildup": 2.0, "combat": 2.0, "fighting": 1.5,
        "drone": 1.0, "artillery": 1.5, "missile": 2.0, "rocket": 1.5,
        "terror": 2.5, "explosion": 1.5, "bomb": 2.0,
        "protest": 1.0, "riot": 1.5, "unrest": 1.0,
        "sanctions": 0.5, "ultimatum": 1.5, "tensions": 1.0,
    }

    threat_score = 0.0
    detected_threats = []

    for indicator, weight in threat_indicators.items():
        if indicator in content_lower:
            threat_score += weight
            detected_threats.append(indicator)

    threat_score = min(10.0, threat_score)

    # Actor extraction
    actors = extract_actors_rule_based(content_lower)

    # Location extraction
    locations = extract_locations_rule_based(content_lower)

    # Conflict type classification
    conflict_type = classify_conflict(content_lower)

    return {
        "threat_level": round(threat_score, 1),
        "key_actors": actors,
        "key_locations": locations,
        "conflict_type": conflict_type,
        "confidence": 0.8 if not GEMINI_API_KEY else 0.95,
        "recommendation": "Escalate" if threat_score >= 5 else "Monitor",
        "detected_threats": detected_threats,
        "analysis_method": "gemini_api" if GEMINI_API_KEY else "rule_based"
    }


def extract_actors_rule_based(text):
    """Extract known actors using pattern matching."""
    known_actors = [
        "russia", "ukraine", "usa", "china", "israel", "iran", "hamas",
        "hezbollah", "taliban", "isis", "russian", "ukrainian", "chinese",
        "military", "army", "troops", "soldiers", "rebels", "militia",
    ]

    found = []
    for actor in known_actors:
        if actor in text:
            found.append(actor.title())

    return list(set(found))[:5]


def extract_locations_rule_based(text):
    """Extract known locations using pattern matching."""
    known_locations = [
        "ukraine", "gaza", "israel", "russia", "china", "taiwan",
        "india", "pakistan", "kashmir", "myanmar", "syria", "iraq",
        "iran", "sudan", "ethiopia", "somalia", "haiti", "mexico",
        "donbas", "crimea", "bakhmut", "mekong", "south china sea",
    ]

    found = []
    for loc in known_locations:
        if loc in text:
            found.append(loc.title())

    return list(set(found))[:5]


def classify_conflict(text):
    """Classify the type of conflict."""
    if any(w in text for w in ["military", "army", "soldiers", "combat", "tanks", "artillery"]):
        return "military"
    elif any(w in text for w in ["political", "diplomat", "talks", "negotiations", "sanctions"]):
        return "political"
    elif any(w in text for w in ["civilians", "refugees", "humanitarian", "aid", "food"]):
        return "humanitarian"
    elif any(w in text for w in ["cyber", "hack", "digital", "internet"]):
        return "cyber"
    else:
        return "general"


