)

# Initialize database on startup
init_db()

# Background processing flag
processing_active = False

class SignalIngest(BaseModel):
    source: str
    content: str
    geo_tag: Optional[str] = None
    language: Optional[str] = "en"

class BriefUpdate(BaseModel):
    status: str

class ManualBrief(BaseModel):
    title: str
    content: str
    threat_score: float

def run_pipeline_cycle():
    """Run one cycle of the processing pipeline."""
    try:
        signals = []
        mode = "unknown"

        # Always try real data sources first (RSS feeds work without keys)
        real_signals = fetch_all_sources()

        if real_signals:
            # Use real data from RSS/NewsAPI/GDELT
            signals = real_signals
            mode = "REAL_DATA"
        elif USE_SIMULATOR:
            # Fall back to simulator only if no real data available
            signals = generate_batch(random.randint(3, 8))
            mode = "SIMULATOR"
        else:
            # No data sources available
            signals = []
            mode = "NO_DATA"

        # Limit signals to avoid overload
        signals = signals[:20]

        # Process signals
        briefs_generated = 0
        for signal in signals:
            # Insert into database
            signal_id = insert_signal(signal)

            # Preprocess
            signal = preprocess_signal(signal)

            # Get AI analysis
            analysis = analyze_with_gemini(signal.get("content", ""))

            # Update with analysis
            signal["hostility_score"] = analysis.get("threat_level", 0) / 10
            signal["sentiment_score"] = -0.3 if analysis.get("threat_level", 0) > 5 else 0.0

            # Add to feed
            sentiment_label = get_threat_level(analysis.get("threat_level", 0))
            insert_feed_item({
                "source": signal.get("source", "System"),
                "content": signal.get("content", "")[:200],
                "timestamp": signal.get("timestamp"),
                "sentiment": sentiment_label
            })

        # Auto-generate briefs for high-threat signals
        briefs_generated = auto_generate_briefs(signals, THREAT_THRESHOLD)

        # Update system stats
        update_system_stats({
            "active_briefs": get_brief_count(),
            "high_priority": get_high_priority_count(THREAT_THRESHOLD),
            "sources_monitored": 1500 if mode.startswith("REAL") else 847,
            "regions_covered": 195 if mode.startswith("REAL") else 12,
        })

        print(f"[{datetime.now().isoformat()}] Pipeline: {len(signals)} signals, {len(briefs_generated)} briefs ({mode})")

    except Exception as e:
        print(f"Pipeline error: {e}")
        import traceback
        traceback.print_exc()

def background_processor():
    """Background thread that runs the processing pipeline periodically."""
    global processing_active
    interval = 30  # Run every 30 seconds

    while processing_active:
        run_pipeline_cycle()
        time.sleep(interval)

@app.on_event("startup")
async def startup_event():
    """Start the background processor on server startup."""
    global processing_active
    processing_active = True
    threading.Thread(target=background_processor, daemon=True).start()

    # Determine mode
    if USE_SIMULATOR and not NEWSAPI_KEY and not GEMINI_API_KEY:
        mode = "SIMULATOR MODE (no API keys configured)"
    else:
        sources = []
        if USE_REDDIT: sources.append("Reddit")
        if USE_YOUTUBE: sources.append("YouTube")
        if NEWSAPI_KEY: sources.append("NewsAPI")
        if GEMINI_API_KEY: sources.append("Gemini AI")
        mode = f"REAL DATA MODE: {', '.join(sources)}"

    print(f"CEWS Backend started. {mode}")
    print(f"Threat threshold: {THREAT_THRESHOLD}")

@app.on_event("shutdown")
async def shutdown_event():
    """Stop the background processor on server shutdown."""
    global processing_active
    processing_active = False

