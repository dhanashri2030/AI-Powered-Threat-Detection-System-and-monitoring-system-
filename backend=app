@app.post("/api/signals")
async def ingest_signal(signal: SignalIngest):
    """Manually ingest a signal."""
    signal_dict = signal.dict()
    signal_dict["timestamp"] = datetime.utcnow().isoformat()
    signal_dict["sentiment_score"] = 0.0
    signal_dict["hostility_score"] = 0.0
    signal_dict["actors"] = []
    signal_dict["locations"] = []

    signal_id = insert_signal(signal_dict)

    # Run through analyzer
    analysis = analyze_with_gemini(signal.content)
    signal_dict["hostility_score"] = analysis.get("threat_level", 0) / 10
    signal_dict["sentiment_score"] = -0.3 if analysis.get("threat_level", 0) > 5 else 0.0

    # Check if brief should be generated
    patterns = detect_pattern(signal_dict)
    threat_score = calculate_threat_score(signal_dict, patterns)

    if threat_score >= THREAT_THRESHOLD:
        briefs = auto_generate_briefs([signal_dict], THREAT_THRESHOLD)
        return {"signal_id": signal_id, "analysis": analysis, "briefs_generated": len(briefs)}

    return {"signal_id": signal_id, "analysis": analysis, "briefs_generated": 0}

