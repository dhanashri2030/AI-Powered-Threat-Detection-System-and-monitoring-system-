@app.post("/api/pipeline/run")
async def trigger_pipeline():
    """Manually trigger a pipeline cycle."""
    run_pipeline_cycle()
    return {"status": "pipeline_run_complete"}

@app.get("/api/analyze/{signal_id}")
async def analyze_signal(signal_id: int):
    """Get detailed analysis for a specific signal."""
    signals = get_recent_signals(24, 1000)
    signal = None
    for s in signals:
        if s.get("id") == signal_id:
            signal = s
            break

    if not signal:
        raise HTTPException(status_code=404, detail="Signal not found")

    patterns = detect_pattern(signal)
    threat_score = calculate_threat_score(signal, patterns)
    analysis = analyze_with_gemini(signal.get("content", ""))

    return {
        "signal": signal,
        "patterns": patterns,
        "threat_score": threat_score,
        "threat_level": get_threat_level(threat_score),
        "analysis": analysis,
    }

